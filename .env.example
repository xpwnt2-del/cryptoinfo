# ── Exchange API Keys (required only for live trading) ──────────────────────
# Supported exchange IDs: binance, coinbase, kraken, bybit, okx, mexc
EXCHANGE_ID=binance
EXCHANGE_API_KEY=your_api_key_here
EXCHANGE_SECRET=your_api_secret_here

# ── OpenAI (optional – enables GPT-powered analysis) ────────────────────────
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o-mini

# ── Bot Settings ─────────────────────────────────────────────────────────────
# Set to "true" to prevent real orders from being placed (default: true)
DRY_RUN=true
# How often the bot checks for new signals, in seconds
BOT_INTERVAL=60
# Minimum signal confidence required to place a trade (0-100)
MIN_CONFIDENCE=70
# Amount of each bot-placed market order (in base currency units, e.g. BTC)
BOT_TRADE_AMOUNT=0.001

# ── App Settings ─────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-string
DEBUG=false
PORT=5000
